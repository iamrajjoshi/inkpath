{
  "name": "@iamrajjoshi/inkpath",
  "version": "0.1.0",
  "description": "Build static notes and documentation sites from Markdown.",
  "type": "module",
  "license": "MIT",
  "author": "Raj Joshi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamrajjoshi/inkpath.git"
  },
  "homepage": "https://github.com/iamrajjoshi/inkpath#readme",
  "bugs": {
    "url": "https://github.com/iamrajjoshi/inkpath/issues"
  },
  "keywords": [
    "documentation",
    "markdown",
    "notes",
    "static-site-generator"
  ],
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "inkpath": "dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsx src/cli.ts check examples/basic",
    "dev": "tsx src/cli.ts dev examples/basic",
    "example:build": "tsx src/cli.ts build examples/basic",
    "package:check": "node scripts/package-check.mjs",
    "prepare": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm verify",
    "test": "pnpm build && node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm test && pnpm check && pnpm example:build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chokidar": "5.0.0",
    "esbuild": "0.28.1",
    "highlight.js": "11.11.1",
    "markdown-it": "14.3.0",
    "markdown-it-footnote": "4.0.0",
    "mermaid": "11.16.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/markdown-it": "14.1.2",
    "@types/markdown-it-footnote": "3.0.4",
    "@types/node": "22.19.19",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
